# Copie para .env.local e preencha com seus dados do Firebase Console
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# URL das Cloud Functions após deploy
# Local:    http://127.0.0.1:5001/SEU-PROJETO/us-central1
# Produção: https://us-central1-SEU-PROJETO.cloudfunctions.net
VITE_FUNCTIONS_URL=http://127.0.0.1:5001/SEU-PROJETO/us-central1
