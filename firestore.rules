rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function loggedIn() {
      return request.auth != null;
    }

    // Pacientes — leitura e escrita para qualquer usuário autenticado
    match /patients/{id} {
      allow read, write: if loggedIn();
    }

    // Sessões de testes — leitura e escrita para qualquer usuário autenticado
    match /sessions/{id} {
      allow read, write: if loggedIn();
    }

    // Laudos — leitura e escrita para qualquer usuário autenticado
    match /reports/{id} {
      allow read, write: if loggedIn();
    }

    // Notas clínicas — leitura e escrita para qualquer usuário autenticado
    match /notes/{id} {
      allow read, write: if loggedIn();
    }

    // Perfis de usuário — leitura e escrita para qualquer usuário autenticado
    match /users/{id} {
      allow read, write: if loggedIn();
    }

    // Profissionais importados do ProDoctor
    match /professionals/{id} {
      allow read, write: if loggedIn();
    }
  }
}
