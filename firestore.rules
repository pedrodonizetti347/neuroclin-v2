rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isHardcodedAdmin() {
      return request.auth != null && request.auth.uid == 'i5nwg569WabTUk69wzCWV5PRw9E3';
    }

    function userRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdminOrSupervisor() {
      return request.auth != null && (isHardcodedAdmin() || userRole() in ['admin', 'supervisor']);
    }

    function isAuth() {
      return request.auth != null;
    }

    // Perfis de usuário
    match /users/{userId} {
      allow read: if isAuth() && (request.auth.uid == userId || isAdminOrSupervisor());
      allow write: if isAdminOrSupervisor();
      // Profissional pode criar o próprio perfil no primeiro login Google
      allow create: if isAuth() && request.auth.uid == userId;
      // Profissional pode atualizar próprio perfil (last_login, photo_url) mas não escala role/active
      allow update: if isAuth() && request.auth.uid == userId
                    && request.resource.data.role == resource.data.role
                    && request.resource.data.active == resource.data.active;
    }

    // Pacientes — qualquer autenticado lê; só admin/supervisor escreve
    match /patients/{patientId} {
      allow read: if isAuth();
      allow write: if isAdminOrSupervisor();
    }

    // Sessões de testes — admin vê todas; profissional só vê as suas
    match /sessions/{sessionId} {
      allow read, write: if isAdminOrSupervisor();
      allow read, update, delete: if isAuth() && resource.data.professionalId == request.auth.uid;
      allow create: if isAuth() && request.resource.data.professionalId == request.auth.uid;
    }

    // Laudos — admin vê todos; profissional só vê os seus
    match /reports/{reportId} {
      allow read, write: if isAdminOrSupervisor();
      allow read, update, delete: if isAuth() && resource.data.professionalId == request.auth.uid;
      allow create: if isAuth() && request.resource.data.professionalId == request.auth.uid;
    }

    // Observações clínicas (notes) — por patientId; profissional acessa se for dono do paciente
    match /notes/{patientId} {
      allow read, write: if isAdminOrSupervisor();
      allow read, write: if isAuth() && get(/databases/$(database)/documents/patients/$(patientId)).data.createdBy == request.auth.uid;
    }

    // Anamneses clínicas — qualquer autenticado lê e escreve
    match /anamneses/{patientId} {
      allow read, write: if isAuth();
    }

    // Configurações da clínica — apenas admin/supervisor
    match /clinic_settings/{doc} {
      allow read, write: if isAdminOrSupervisor();
    }
  }
}
