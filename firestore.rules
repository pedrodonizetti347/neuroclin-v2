rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isHardcodedAdmin() {
      return request.auth != null && request.auth.uid == 'i5nwg569WabTUk69wzCWV5PRw9E3';
    }

    function userRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdminOrSupervisor() {
      return request.auth != null && (isHardcodedAdmin() || userRole() in ['admin', 'supervisor']);
    }

    function isAuth() {
      return request.auth != null;
    }

    function isEstagiario() {
      return isAuth() && userRole() == 'estagiario';
    }

    function isEntregador() {
      return isAuth() && userRole() == 'entregador';
    }

    // Perfis de usuário — leitura simples sem get() circular
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow read: if isAdminOrSupervisor();
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId
                    && request.resource.data.diff(resource.data).affectedKeys()
                       .hasOnly(['last_login', 'must_change_password', 'photo_url']);
      allow update, delete: if isAdminOrSupervisor();
    }

    // Pacientes — qualquer autenticado lê e cria; só admin/supervisor atualiza
    // DELETE bloqueado via cliente — exclusão é sempre soft-delete (deleted:true)
    match /patients/{patientId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isAdminOrSupervisor();
      allow delete: if false;
    }

    // Sessões de testes — qualquer autenticado lê e escreve (create/update)
    // DELETE bloqueado via cliente — dados clínicos jamais são apagados diretamente
    match /sessions/{sessionId} {
      allow read: if isAuth();
      allow create, update: if isAuth();
      allow delete: if false;
    }

    // Laudos — admin/supervisor tem acesso total; profissional acessa os seus
    // Entregador lê e atualiza apenas laudos aprovados
    // DELETE bloqueado via cliente — exclusão é sempre soft-delete (deleted:true)
    match /reports/{reportId} {
      allow read, create, update: if isAdminOrSupervisor();
      allow read, create, update: if isAuth() && resource.data.professionalId == request.auth.uid;
      allow create: if isAuth() && request.resource.data.professionalId == request.auth.uid;
      allow read, update: if isEntregador();
      allow delete: if false;
    }

    // Observações clínicas (notes) — por patientId
    match /notes/{patientId} {
      allow read, create, update: if isAdminOrSupervisor();
      allow read, create, update: if isAuth() && get(/databases/$(database)/documents/patients/$(patientId)).data.createdBy == request.auth.uid;
      allow delete: if false;
    }

    // Anamneses clínicas — DELETE bloqueado; qualquer autenticado cria/atualiza
    match /anamneses/{patientId} {
      allow read: if isAuth();
      allow create, update: if isAuth();
      allow delete: if false;
    }

    // Configurações da clínica — apenas admin/supervisor
    match /clinic_settings/{doc} {
      allow read, write: if isAdminOrSupervisor();
    }

    // Log de auditoria — qualquer autenticado grava; só admin/supervisor lê
    // DELETE bloqueado — logs são imutáveis
    match /audit_logs/{logId} {
      allow read: if isAdminOrSupervisor();
      allow create: if isAuth();
      allow update, delete: if false;
    }
  }
}
