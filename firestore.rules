rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isHardcodedAdmin() {
      return request.auth != null && request.auth.uid == 'i5nwg569WabTUk69wzCWV5PRw9E3';
    }

    function userRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdminOrSupervisor() {
      return request.auth != null && (isHardcodedAdmin() || userRole() in ['admin', 'supervisor']);
    }

    function isAuth() {
      return request.auth != null;
    }

    function isEstagiario() {
      return isAuth() && userRole() == 'estagiario';
    }

    function isEntregador() {
      return isAuth() && userRole() == 'entregador';
    }

    function isAdmin() {
      return isAdminOrSupervisor();
    }

    function isBeliane() {
      return isAuth() && (isAdminOrSupervisor() || userRole() == 'secretaria');
    }

    function isProfissional() {
      return isAuth() && userRole() in ['profissional', 'professional'];
    }

    // Perfis de usuário
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow read: if isAdminOrSupervisor();
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId
                    && request.resource.data.diff(resource.data).affectedKeys()
                       .hasOnly(['last_login', 'must_change_password', 'photo_url']);
      allow update, delete: if isAdminOrSupervisor();
    }

    // Pacientes
    match /patients/{patientId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isAdminOrSupervisor();
      allow delete: if false;
    }

    // Sessões de testes
    match /sessions/{sessionId} {
      allow read: if isAuth();
      allow create, update: if isAuth();
      allow delete: if false;
    }

    // Laudos
    match /reports/{reportId} {
      allow read, create, update: if isAdminOrSupervisor();
      allow read, create, update: if isAuth() && resource.data.professionalId == request.auth.uid;
      allow create: if isAuth() && request.resource.data.professionalId == request.auth.uid;
      allow read, update: if isEntregador();
      allow delete: if false;
    }

    // Observações clínicas
    match /notes/{patientId} {
      allow read, create, update: if isAdminOrSupervisor();
      allow read, create, update: if isAuth() && get(/databases/$(database)/documents/patients/$(patientId)).data.createdBy == request.auth.uid;
      allow delete: if false;
    }

    // Anamneses clínicas
    match /anamneses/{patientId} {
      allow read: if isAuth();
      allow create, update: if isAuth();
      allow delete: if false;
    }

    // Configurações da clínica
    match /clinic_settings/{doc} {
      allow read, write: if isAdminOrSupervisor();
    }

    // Log de auditoria
    match /audit_logs/{logId} {
      allow read: if isAdminOrSupervisor();
      allow create: if isAuth();
      allow update, delete: if false;
    }

    // Controle de correções e fluxo de avaliação
    match /correcoes/{correcaoId} {
      // Leitura:
      //   admin/beliane → tudo
      //   estagiário → apenas os seus
      //   profissional → os seus + os sem atribuição (para self-assign)
      allow read: if isAuth() && (
        isBeliane() ||
        (isEstagiario() && resource.data.estagiarioId == request.auth.uid) ||
        (isProfissional() && (
          resource.data.profissionalUid == request.auth.uid ||
          resource.data.profissionalUid == null
        ))
      );

      // Criação: apenas admin/beliane (inclui sincronização pelo fluxoAvaliacaoService)
      allow create: if isBeliane();

      // Atualização: regras por role
      allow update: if isAuth() && (
        isBeliane() ||

        // Estagiário: transições de etapa (novo fluxo) e status (legado)
        (
          isEstagiario() &&
          resource.data.estagiarioId == request.auth.uid &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'etapaAtual', 'assumidoEm', 'finalizadoEm',
            'status', 'dataInicioCorrecao', 'dataFinalizacao'
          ]) &&
          (
            (resource.data.etapaAtual == 'aguardando_correcao'   && request.resource.data.etapaAtual == 'em_correcao') ||
            (resource.data.etapaAtual == 'em_correcao'           && request.resource.data.etapaAtual == 'aguardando_aprovacao') ||
            (resource.data.status     == 'aguardando'            && request.resource.data.status     == 'corrigindo') ||
            (resource.data.status     == 'corrigindo'            && request.resource.data.status     == 'finalizado')
          )
        ) ||

        // Profissional: auto-atribuição (quando profissionalUid é null) ou atualização de anamnese
        (
          isProfissional() &&
          (resource.data.profissionalUid == null || resource.data.profissionalUid == request.auth.uid) &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'profissionalUid', 'profissionalNome',
            'anamnese_preenchida', 'anamnesePreenchidaEm'
          ])
        ) ||

        // Qualquer autenticado pode marcar anamnese como preenchida (fire-and-forget do AnamneseForm)
        (
          isAuth() &&
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['anamnese_preenchida', 'anamnesePreenchidaEm']) &&
          request.resource.data.anamnese_preenchida == true
        )
      );

      allow delete: if isAdmin();
    }
  }
}
